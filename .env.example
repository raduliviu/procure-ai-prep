# ----------------------------------------------------------------
# Procure AI Prep — environment template
# Copy this to .env at the project root:   cp .env.example .env
# The real .env is gitignored; never commit it.
# ----------------------------------------------------------------

# --- Postgres (consumed by docker-compose.yml) ---
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=procure_dev
POSTGRES_PORT=5432

# --- API (apps/api) ---
# Full connection string used by Drizzle + the API runtime.
# Matches the POSTGRES_* values above for local dev.
DATABASE_URL=postgres://postgres:postgres@localhost:5432/procure_dev
API_PORT=3001

# --- Web (apps/web) ---
# Vite only exposes variables prefixed with VITE_ to the browser bundle.
VITE_API_URL=http://localhost:3001

# --- OpenAI ---
OPENAI_API_KEY=sk-REPLACE_ME
OPENAI_MODEL=gpt-4o-mini
