# ----------------------------------------------------------------
# Environment template
# Copy this to .env at the project root:   cp .env.example .env
# The real .env is gitignored; never commit it.
# ----------------------------------------------------------------

# --- Postgres (consumed by docker-compose.yml) ---
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=app_dev
POSTGRES_PORT=5432

# --- API (apps/api) ---
# Full connection string for Drizzle + the API runtime.
# Matches the POSTGRES_* values above for local dev.
DATABASE_URL=postgres://postgres:postgres@localhost:5432/app_dev
API_PORT=3001

# --- Web (apps/web) ---
# Vite only exposes variables prefixed with VITE_ to the browser bundle.
# Leave unset to use the /api/* dev proxy defined in vite.config.ts.
VITE_API_URL=

# Add any other secrets your product needs below (LLM keys, OAuth, etc.).
